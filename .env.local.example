# Public web configuration
NEXT_PUBLIC_WORLDCOIN_APP_ID=app_your_world_app_id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_XMTP_ENV=production
NEXT_PUBLIC_XMTP_AGENT_ADDRESS=0xYourAgentWalletAddress
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
NEXT_PUBLIC_EXECUTION_CHAIN=base-sepolia
NEXT_PUBLIC_DEFAULT_PAYMENT_NETWORK=base-sepolia
NEXT_PUBLIC_SUPPORTED_PAYMENT_NETWORKS=base-sepolia
NEXT_PUBLIC_BASE_SEPOLIA_VAULT_FACTORY=0xYourVaultFactoryAddress
NEXT_PUBLIC_BASE_SEPOLIA_SWAP_ADAPTER=0xYourAllowedExecutionTarget
NEXT_PUBLIC_BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# World ID server configuration
WORLDID_API_KEY=api_or_sk_value
WORLD_ID_RP_ID=rp_your_world_rp_id
WORLD_ID_RP_SIGNING_KEY=0xyour_world_rp_signing_key

# Redis
UPSTASH_REDIS_URL=redis://default:password@host:port

# RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Cerberus authorization signer
CERBERUS_SIGNER_PRIVATE_KEY=0xyour_private_key

# Agent worker
XMTP_ENV=production
XMTP_WALLET_KEY=0xyour_agent_private_key
XMTP_DB_ENCRYPTION_KEY=0xyour_32_byte_hex_key
XMTP_DB_PATH=./data/xmtp-agent.db3

# AgentKit / analysis
OPENAI_API_KEY=sk-your-openai-key
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
NETWORK_ID=base-sepolia

# Optional: enable World as an x402 payment network using a World-compatible facilitator
WORLD_X402_FACILITATOR_URL=https://your-world-facilitator.example
WORLD_X402_BEARER_TOKEN=optional_bearer_token
WORLD_X402_CHAIN_ID=480
